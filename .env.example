# ──────────────────────────────────────
# OrderFlow Environment Variables
# Copy this to .env.local and fill in your values
# ──────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-string-at-least-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Resend Email
RESEND_API_KEY=re_...

# Base URL — your production domain
NEXT_PUBLIC_BASE_URL=https://orderflow.co.uk

# Shopify App
SHOPIFY_API_KEY=your-shopify-app-api-key
SHOPIFY_API_SECRET=your-shopify-app-secret
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-hmac-secret

# Internal server-to-server secret (used by /api/shopify/orders POST)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=generate-a-random-string-at-least-32-chars

# Cron job authentication secret (used by all /api/cron/* routes)
# Must match the secret sent in Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-a-random-string-at-least-32-chars

# API Gateway (Cloudflare Worker)
# Required — gateway will refuse to start without this
API_GATEWAY_API_KEY=your-api-key-for-v1-orders-and-webhooks
CORS_ORIGINS=https://your-app.com,https://admin.orderflow.co.uk

# Rate Limiting — Upstash Redis (optional, falls back to in-memory)
# Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Alerting (optional — used by packages/security for critical alerts)
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/...
ALERT_EMAIL=alerts@your-domain.com

# SMS monthly spend cap (default: 500 messages/month per restaurant)
SMS_MONTHLY_CAP=500

# Environment
NODE_ENV=development
